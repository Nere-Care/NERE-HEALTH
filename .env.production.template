# 🔒 CONFIGURATION PRODUCTION - TEMPLATE
# COPIER EN .env ET REMPLIR AVEC DES VALEURS REELLES GENEREES EN SECURITE
# ⚠️  JAMAIS COMMIT AVEC DES VALEURS REELLES

# === DATABASE ===
DATABASE_URL=postgresql://nere_app_user:GENERATED_SECURE_PASSWORD@db-host:5432/nere_db

# === SECURITY ===
SECRET_KEY=GENERATED_64_CHAR_RANDOM_STRING_MIN_64_CHARS
ENVIRONMENT=production
DEBUG=false

# === CORS & HOSTS ===
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# === API PREFIX ===
API_PREFIX=/api/v1

# === OPENAI (Phase 3) ===
OPENAI_API_KEY=sk-GENERATED_KEY_FROM_OPENAI
OPENAI_MODEL=gpt-4o-mini

# === STRIPE (Phase 3) ===
STRIPE_API_KEY=sk_live_GENERATED_KEY_FROM_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_GENERATED_WEBHOOK_SECRET_FROM_STRIPE
STRIPE_SUCCESS_URL=https://yourdomain.com/payment/success
STRIPE_CANCEL_URL=https://yourdomain.com/payment/cancel

# === MONITORING ===
SENTRY_DSN=https://GENERATED_KEY@sentry.io/PROJECT_ID

# === POSTGRES ADMIN (CHANGEMENT IMMEDIAT) ===
POSTGRES_USER=nere_app_user
POSTGRES_PASSWORD=GENERATED_SECURE_PASSWORD_MIN_32_CHARS
POSTGRES_DB=nere_db

# === PORTS (INTERNE SEULEMENT) ===
DB_HOST_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=443
