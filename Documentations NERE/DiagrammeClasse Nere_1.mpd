<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_generate_consultation_numero() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.numero_consultation IS NULL
    OR NEW.numero_consultation = &#39;&#39; THEN NEW.numero_consultation := fn_generate_numero(&#39;CONS&#39;, &#39;seq_consultation_numero&#39;)</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
