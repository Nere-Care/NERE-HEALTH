<o:Procedure Id="o44">
<a:ObjectID>3F27636C-D105-489B-A352-DDB2616C0711</a:ObjectID>
<a:Name>public</a:Name>
<a:Code>public</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_audit_trigger() RETURNS trigger
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
DECLARE v_action action_audit</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o46">
<a:ObjectID>A29F57EC-931C-40F2-89B9-B991C5E1434B</a:ObjectID>
<a:Name>public</a:Name>
<a:Code>public</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_calc_duree_consultation() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.date_heure_fin IS NOT NULL
    AND NEW.date_heure_debut IS NOT NULL THEN NEW.duree_minutes := EXTRACT(
        EPOCH
        FROM (NEW.date_heure_fin - NEW.date_heure_debut)
    ) / 60</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o48">
<a:ObjectID>C296F5FF-3F15-400E-AB99-23467A800B8D</a:ObjectID>
<a:Name>public</a:Name>
<a:Code>public</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_calc_imc() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.taille_cm &gt; 0
    AND NEW.poids_kg &gt; 0 THEN NEW.imc := ROUND(
        NEW.poids_kg / POWER(NEW.taille_cm / 100.0, 2),
        2
    )</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o50">
<a:ObjectID>FA8EB459-0F20-4994-B650-A112A6B26DE5</a:ObjectID>
<a:Name>public</a:Name>
<a:Code>public</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_calc_montant_medecin() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.montant_medecin IS NULL THEN NEW.montant_medecin := NEW.montant_total - NEW.frais_plateforme</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o51">
<a:ObjectID>2762F60A-4AA4-4436-85AB-C180B4045EB6</a:ObjectID>
<a:Name>public</a:Name>
<a:Code>public</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_create_dossier_on_patient() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN
INSERT INTO dossiers_medicaux (patient_id)
VALUES (NEW.id)</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o53">
