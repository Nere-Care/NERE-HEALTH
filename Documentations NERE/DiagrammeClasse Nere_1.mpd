.fn_verifier_disponibilite(p_medecin_id uuid, p_debut timestamp with time zone, p_fin timestamp with time zone) RETURNS boolean
    LANGUAGE plpgsql
    AS $$
DECLARE v_conflit INTEGER</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
