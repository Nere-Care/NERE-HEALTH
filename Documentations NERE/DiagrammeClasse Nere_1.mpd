<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_generate_ordonnance_numero() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.numero IS NULL
    OR NEW.numero = &#39;&#39; THEN NEW.numero := fn_generate_numero(&#39;ORD&#39;, &#39;seq_ordonnance_numero&#39;)</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o61">
<a:ObjectID>2D54BCF9-3E1F-4DB3-B3AF-F3C6D019A443</a:ObjectID>
