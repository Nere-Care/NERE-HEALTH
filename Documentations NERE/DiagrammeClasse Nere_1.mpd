<a:Modifier>THINKPAD 460</a:Modifier>
<a:Procedure.Text>create or replace function %FUNC%
.fn_generate_paiement_reference() RETURNS trigger
    LANGUAGE plpgsql
    AS $$ BEGIN IF NEW.reference IS NULL
    OR NEW.reference = &#39;&#39; THEN NEW.reference := fn_generate_numero(&#39;NER-PAY&#39;, &#39;seq_paiement_numero&#39;)</a:Procedure.Text>
