<a:Modifier>THINKPAD 460</a:Modifier>
<a:Type>5</a:Type>
<a:ServerExpression>(duree_creneau_minutes = ANY (ARRAY[15, 20, 30, 45, 60, 90]))</a:ServerExpression>
</o:BusinessRule>
<o:BusinessRule Id="o105">
