<o:BusinessRule Id="o103">
<a:ObjectID>2D430B06-66FD-4A34-80DA-1E42FA06C6CE</a:ObjectID>
<a:Name>chk_dispo_validite</a:Name>
<a:Code>chk_dispo_validite</a:Code>
<a:CreationDate>1773578735</a:CreationDate>
<a:Creator>THINKPAD 460</a:Creator>
<a:ModificationDate>1773578765</a:ModificationDate>
<a:Modifier>THINKPAD 460</a:Modifier>
<a:Type>5</a:Type>
<a:ServerExpression>((date_fin_validite IS NULL) OR (date_fin_validite &gt;= date_debut_validite))</a:ServerExpression>
</o:BusinessRule>
<o:BusinessRule Id="o104">
<a:ObjectID>918A3495-B3D8-4CE4-9401-98B08A0EF690</a:ObjectID>
<a:Name>disponibilites_duree_creneau_minutes_check</a:Name>
