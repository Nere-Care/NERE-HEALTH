<a:Procedure.Text>create or replace function %FUNC%
.fn_generate_numero(prefix text, seq_name text) RETURNS text
    LANGUAGE plpgsql
    AS $$
DECLARE next_val BIGINT</a:Procedure.Text>
<a:Procedure.Function>1</a:Procedure.Function>
</o:Procedure>
<o:Procedure Id="o59">
<a:ObjectID>83BFE562-7C81-44FC-859F-9B23D311E192</a:ObjectID>
