# Example environment variables for Nere_app backend
DATABASE_URL=postgresql://nere_user:nere_pass@db:5432/nere_db
CORS_ORIGINS=http://localhost:4173,http://localhost:5173
ENVIRONMENT=development
API_PREFIX=/api
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Phase 3: Payments (Stripe)
STRIPE_API_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
STRIPE_SUCCESS_URL=https://nere.app/payment/success
STRIPE_CANCEL_URL=https://nere.app/payment/cancel

# Phase 3: AI (OpenAI)
OPENAI_API_KEY=sk-proj-your_openai_key
OPENAI_MODEL=gpt-4o-mini
