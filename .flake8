[flake8]
max-line-length = 88
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .env,
    **/alembic/versions,
    .tox,
    build,
    dist
ignore =
    E203,
    E266,
    E501,
    E305,
    W503,
    W504,
    E402
per-file-ignores =
    __init__.py:F401
    tests/*:F401
    conftest.py:F401
